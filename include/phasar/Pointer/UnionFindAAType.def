#ifndef UNIONFIND_ALIAS_ANALYSIS_TYPE
#define UNIONFIND_ALIAS_ANALYSIS_TYPE(NAME, CMDFLAG, DESC)
#endif

UNIONFIND_ALIAS_ANALYSIS_TYPE(CtxSens, "ctx-sens", "Context-sensitive analysis with k=1 heap-cloning")
UNIONFIND_ALIAS_ANALYSIS_TYPE(IndSens, "ind-sens", "Pointer-indirection-sensitive analysis with k=5 heap-cloning")
UNIONFIND_ALIAS_ANALYSIS_TYPE(CtxIndSens, "ctx-ind-sens", "Intersection of ctx-sens and ind-sens")
UNIONFIND_ALIAS_ANALYSIS_TYPE(BotCtxSens, "botctx-sens", "Unbounded context-sensitive analysis, but only provides function-local results")
UNIONFIND_ALIAS_ANALYSIS_TYPE(BotCtxIndSens, "botctx-ind-sens", "Intersection of botctx-sens and ind-sens")

#undef UNIONFIND_ALIAS_ANALYSIS_TYPE
